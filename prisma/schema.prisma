// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id     String @id
  pseudo String @unique
  email  String @unique

  pictoId String

  picto Picto @relation(fields: [pictoId], references: [id])

  status String

  consentVersion    String?
  consentAcceptedAt DateTime?

  createdAt DateTime

  confirmationTokens ConfirmationToken[]
  
  secondConfirmationSentAt DateTime?

  otps               Otp[]
}

model ConfirmationToken {
  id String @id

  value String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id])

  status String

  expiresAt DateTime
  createdAt DateTime
}

model Otp {
  id String @id

  value String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id])

  status String

  attempts Int

  expiresAt DateTime

  blockedUntil DateTime?

  createdAt DateTime
}

model Picto {
  id       String @id
  label    String
  imageUrl String

  users User[]
}